# Primary LLM Configuration
LLM_PROVIDER=gemini
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# Secondary LLM Configuration
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Frontend Configuration
FRONTEND_API_BASE=https://dev-ai-hiring-assistance-api.gemicates.in
FRONTEND_API_TOKEN=replace-with-your-frontend-api-token

# Backend Configuration
BACKEND_API_KEY=replace-with-your-backend-api-key

# Apify Configuration
APIFY_API_KEY=replace-with-your-apify-api-key

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=app.log
